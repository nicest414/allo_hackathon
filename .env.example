# mainプロセスのみが読み込む。renderer/preloadには渡さない（src/main/env.ts経由でのみ参照）。
GEMINI_API_KEY=
DEEPGRAM_API_KEY=

# 差し替えポイント: "deepgram" | "gemini_live" (src/main/stt/createSttProvider.ts が参照)
STT_PROVIDER=deepgram

# --- LLMデバッグ用（任意。詳細は README「LLMデバッグ」参照）---
# LLM_FAKE=1   # 実APIを呼ばず決定的なモック判定を返す（キー無し/オフライン用）
# LLM_DEBUG=1  # Gemini呼び出しのstatus/レイテンシ/生応答をstderrに出す（キーは出さない）
