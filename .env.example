# ============================================================================
# 環境変数テンプレート
#   1. このファイルをコピーして .env を作る:  cp .env.example .env
#   2. 各キーに自分のローカル用の値を設定する（.env は .gitignore 済み）
#
# これらの値は Electron main プロセス（src/main/env.ts）でのみ読み込み、
# preload / renderer には一切渡さない（renderer は DevTools で覗けるため）。
# 取得手順の詳細: docs/development-setup.md
# ============================================================================

# Gemini API キー（返答内容判定 = Gemini Flash で使用）
# 取得: https://aistudio.google.com/apikey （Google アカウントで無料発行）
# STT_PROVIDER=gemini_live の場合は STT でも使用する。
GEMINI_API_KEY=

# Deepgram API キー（STT_PROVIDER=deepgram のとき必須）
# 取得: https://console.deepgram.com/signup （新規登録で無料クレジット付与）
DEEPGRAM_API_KEY=

# STT 実装の差し替えポイント: "deepgram" | "gemini_live"
#   - deepgram    → DEEPGRAM_API_KEY が必須
#   - gemini_live → GEMINI_API_KEY が必須
# (src/main/stt/createSttProvider.ts が参照。未指定時は deepgram)
STT_PROVIDER=deepgram
